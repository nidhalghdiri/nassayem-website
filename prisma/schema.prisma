// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL") // Required for Supabase to bypass connection pooling for migrations
}

// ------------------------------------------------------
// ENUMS — Property rental
// ------------------------------------------------------

enum UnitType {
  STUDIO
  ONE_BEDROOM
  TWO_BEDROOM
  THREE_BEDROOM
  VILLA
}

enum RentType {
  DAILY
  MONTHLY
  BOTH
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  REFUNDED
}

// ------------------------------------------------------
// ENUMS — Staff & Task management
// ------------------------------------------------------

enum StaffRole {
  MANAGER
  SUPERVISOR
  RECEPTIONIST
  HOUSEKEEPING
  MAINTENANCE
}

enum TaskType {
  CLEANING
  INSPECTION
  MAINTENANCE
  WORK_ORDER
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

// Unified status enum — valid values depend on TaskType (enforced in app logic)
enum TaskStatus {
  PENDING_APPROVAL    // Maintenance requests awaiting Manager/Supervisor approval
  ASSIGNED            // Task created and assigned, work not started
  CLEANING_STARTED
  CLEANING_COMPLETED
  INSPECTING
  ISSUES_FOUND
  NO_ISSUES
  WORK_STARTED
  WORK_COMPLETED
  IN_PROGRESS         // Work Order
  COMPLETED           // Work Order final
  ON_HOLD
  CANCELLED
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

// ------------------------------------------------------
// MODELS — Property rental
// ------------------------------------------------------

model Building {
  id            String   @id @default(uuid())
  nameEn        String
  nameAr        String
  locationEn    String
  locationAr    String
  latitude      Float?
  longitude     Float?
  descriptionEn String?
  descriptionAr String?
  imageUrl      String?

  // Relations
  units         Unit[]
  tasks         Task[]
  assignedStaff AdminUserBuilding[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Unit {
  id            String   @id @default(uuid())
  buildingId    String

  unitCode      String?  @unique
  titleEn       String
  titleAr       String
  descriptionEn String   @db.Text
  descriptionAr String   @db.Text

  unitType      UnitType
  rentType      RentType

  dailyPrice    Float?
  monthlyPrice  Float?

  guests        Int      @default(1)
  bedrooms      Int      @default(1)
  beds          Int      @default(1)
  bathrooms     Int      @default(1)

  isPublished   Boolean  @default(false)

  // Relations
  building      Building    @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  images        UnitImage[]
  amenities     Amenity[]
  bookings      Booking[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model UnitImage {
  id           String   @id @default(uuid())
  unitId       String
  url          String
  isMain       Boolean  @default(false)
  displayOrder Int      @default(0)

  unit         Unit     @relation(fields: [unitId], references: [id], onDelete: Cascade)

  createdAt    DateTime @default(now())
}

model Amenity {
  id        String  @id @default(uuid())
  nameEn    String  @unique
  nameAr    String  @unique
  iconSvg   String?

  units     Unit[]

  createdAt DateTime @default(now())
}

model Booking {
  id                String        @id @default(uuid())
  bookingCode       String?       @unique // Short human-readable ID, e.g. NSM-K4X7Q2
  unitId            String

  guestName         String
  guestEmail        String
  guestPhone        String
  guestNationality  String?
  guestNotes        String?
  paymentMethod     String        @default("CARD") // CASH or CARD

  checkIn           DateTime
  checkOut          DateTime
  totalPrice        Float
  status            BookingStatus @default(PENDING)

  unit              Unit          @relation(fields: [unitId], references: [id], onDelete: Restrict)

  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
}

// ------------------------------------------------------
// MODELS — Admin users & Task management
// ------------------------------------------------------

model AdminUser {
  id                String    @id @default(uuid())
  supabaseId        String    @unique
  email             String    @unique
  name              String?
  role              StaffRole @default(MANAGER)
  whatsappNumber    String?            // e.g. "96898590405" — no + or spaces
  preferredLanguage String    @default("en") // "en" or "ar"

  // Task relations
  createdTasks    Task[]         @relation("TaskCreatedBy")
  assignedTasks   Task[]         @relation("TaskAssignedTo")
  approvedTasks   Task[]         @relation("TaskApprovedBy")
  taskNotes       TaskNote[]
  taskPhotos      TaskPhoto[]
  taskActivities  TaskActivity[]
  posts           Post[]

  // Receptionist building scope
  assignedBuildings AdminUserBuilding[]

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

// Receptionist ↔ Building scope (many-to-many)
model AdminUserBuilding {
  adminUserId String
  buildingId  String
  adminUser   AdminUser @relation(fields: [adminUserId], references: [id], onDelete: Cascade)
  building    Building  @relation(fields: [buildingId], references: [id], onDelete: Cascade)

  @@id([adminUserId, buildingId])
  @@index([adminUserId])
}

model Task {
  id          String       @id @default(uuid())
  type        TaskType
  title       String
  description String?      @db.Text

  // Location
  buildingId  String
  unitNumber  String?      // free-text unit name/code, null = common area

  // Priority & status
  priority    TaskPriority @default(MEDIUM)
  status      TaskStatus   @default(ASSIGNED)

  // People
  createdById  String
  assignedToId String

  dueDate      DateTime

  // Sub-task / parent link (Inspection → spawns Cleaning or Maintenance)
  parentTaskId String?

  // Maintenance request approval
  requiresApproval Boolean        @default(false)
  approvedById     String?
  approvalStatus   ApprovalStatus?

  // Relations
  building     Building       @relation(fields: [buildingId], references: [id])
  // (no Unit relation — unitNumber is free text)
  createdBy    AdminUser      @relation("TaskCreatedBy",  fields: [createdById],  references: [id])
  assignedTo   AdminUser      @relation("TaskAssignedTo", fields: [assignedToId], references: [id])
  approvedBy   AdminUser?     @relation("TaskApprovedBy", fields: [approvedById], references: [id])
  parentTask   Task?          @relation("SubTasks", fields: [parentTaskId], references: [id])
  subTasks     Task[]         @relation("SubTasks")

  notes                TaskNote[]
  photos               TaskPhoto[]
  activities           TaskActivity[]
  inspectionChecklist  InspectionChecklist?

  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@index([status])
  @@index([assignedToId])
  @@index([buildingId])
  @@index([dueDate])
  @@index([type])
}

model TaskNote {
  id        String    @id @default(uuid())
  taskId    String
  userId    String
  text      String    @db.Text

  task      Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user      AdminUser @relation(fields: [userId], references: [id])

  createdAt DateTime  @default(now())
}

model TaskPhoto {
  id        String    @id @default(uuid())
  taskId    String
  userId    String
  photoUrl  String
  caption   String?

  task      Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user      AdminUser @relation(fields: [userId], references: [id])

  createdAt DateTime  @default(now())
}

// Auto-generated audit log — one record per meaningful action on a task
model TaskActivity {
  id      String    @id @default(uuid())
  taskId  String
  userId  String
  // action: "task_created" | "status_changed" | "note_added" | "photo_uploaded" | "approved" | "rejected"
  action  String
  details String    @db.Text

  task    Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user    AdminUser @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())

  @@index([taskId])
}

// ── Inspection checklist — created automatically for INSPECTION tasks ─────────

model InspectionChecklist {
  id             String                    @id @default(uuid())
  taskId         String                    @unique
  task           Task                      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  items          InspectionChecklistItem[]
  overallRating  String?                   // "excellent" | "good" | "fair" | "poor"
  inspectorNotes String?                   @db.Text
  completedAt    DateTime?

  createdAt      DateTime                  @default(now())
  updatedAt      DateTime                  @updatedAt

  @@index([taskId])
}

model InspectionChecklistItem {
  id             String              @id @default(uuid())
  checklistId    String
  checklist      InspectionChecklist @relation(fields: [checklistId], references: [id], onDelete: Cascade)

  category       String
  label          String
  status         String              @default("pending") // "pending" | "pass" | "fail" | "na"
  notes          String?             @db.Text
  severity       String?             // "minor" | "major" | "critical"
  photoUrls      String[]            @default([])
  displayOrder   Int                 @default(0)
  followUpTaskId String?
  maintenanceTaskId String?           // ID of the maintenance task if requested from here

  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  @@index([checklistId])
}

// ── Custom Inspection Settings ───────────────────────────────────────────────

model InspectionCategory {
  id           String           @id @default(uuid())
  nameEn       String
  nameAr       String
  displayOrder Int              @default(0)
  items        InspectionItem[]

  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
}

model InspectionItem {
  id           String             @id @default(uuid())
  categoryId   String
  category     InspectionCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  
  labelEn      String
  labelAr      String
  displayOrder Int                @default(0)

  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
}

// ------------------------------------------------------
// MODELS — Blog & Content
// ------------------------------------------------------

model Post {
  id            String   @id @default(uuid())
  slug          String   @unique
  
  titleEn       String
  titleAr       String
  contentEn     String   @db.Text
  contentAr     String   @db.Text
  excerptEn     String?  @db.Text
  excerptAr     String?  @db.Text
  
  coverImage    String?
  isPublished   Boolean  @default(false)

  // Relations
  authorId      String?
  author        AdminUser? @relation(fields: [authorId], references: [id])

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([slug])
  @@index([isPublished])
}
