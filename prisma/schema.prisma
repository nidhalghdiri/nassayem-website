// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL") // Required for Supabase to bypass connection pooling for migrations
}

// ------------------------------------------------------
// ENUMS
// ------------------------------------------------------

enum UnitType {
  STUDIO
  ONE_BEDROOM
  TWO_BEDROOM
  VILLA
}

enum RentType {
  DAILY
  MONTHLY
  BOTH
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

// ------------------------------------------------------
// MODELS
// ------------------------------------------------------

model Building {
  id          String   @id @default(uuid())
  nameEn      String
  nameAr      String
  locationEn  String
  locationAr  String
  latitude    Float?   // For the Leaflet Map
  longitude   Float?   // For the Leaflet Map
  descriptionEn String?
  descriptionAr String?

  imageUrl      String?
  
  // Relations
  units       Unit[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Unit {
  id            String   @id @default(uuid())
  buildingId    String
  
  // Content
  titleEn       String
  titleAr       String
  descriptionEn String   @db.Text
  descriptionAr String   @db.Text
  
  // Categorization
  unitType      UnitType
  rentType      RentType
  
  // Pricing (Stored as Decimal/Float for OMR)
  dailyPrice    Float?
  monthlyPrice  Float?
  
  // Specifications
  guests        Int      @default(1)
  bedrooms      Int      @default(1)
  beds          Int      @default(1)
  bathrooms     Int      @default(1)
  
  // State
  isPublished   Boolean  @default(false)
  
  // Relations
  building      Building    @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  images        UnitImage[]
  amenities     Amenity[]   // Implicit Many-to-Many relation
  bookings      Booking[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model UnitImage {
  id          String   @id @default(uuid())
  unitId      String
  url         String   // The Supabase Storage URL
  isMain      Boolean  @default(false) // To identify the cover image
  displayOrder Int     @default(0)     // To control the slider order
  
  // Relations
  unit        Unit     @relation(fields: [unitId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())
}

model Amenity {
  id          String   @id @default(uuid())
  nameEn      String   @unique
  nameAr      String   @unique
  iconSvg     String?  // Store the SVG path string here so the UI can render it dynamically
  
  // Relations
  units       Unit[]   // Implicit Many-to-Many relation

  createdAt   DateTime @default(now())
}

model Booking {
  id            String   @id @default(uuid())
  unitId        String
  
  // Guest Info (In a full app, this might link to a User model)
  guestName     String
  guestEmail    String
  guestPhone    String
  
  // Booking Details
  checkIn       DateTime
  checkOut      DateTime
  totalPrice    Float
  status        BookingStatus @default(PENDING)
  
  // Relations
  unit          Unit     @relation(fields: [unitId], references: [id], onDelete: Restrict)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}